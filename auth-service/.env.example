# ── Application ───────────────────────────────────────────────────────────────
APP_PORT=8081
APP_ENV=development
GRPC_PORT=9091

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=dv_auth

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL=5m

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_COST=12
